    <DataPropertyAssertion>
        <DataProperty IRI="#hasMeaning"/>
        <NamedIndividual IRI="#Alapadma"/>
        <Literal>A fully bloomed lotus, Wood apple, Circular movement, Breast, Yearning to the beloved, Mirror, Full moon, Beautiful form, Hair-knot, Moon pavilion, Village, Great anger, Pond or lake, Cart, Type of bird, Murmuring sound, Praise</Literal>
    </DataPropertyAssertion>
    <DataPropertyAssertion>
        <DataProperty IRI="#hasSloka"/>
        <NamedIndividual IRI="#Alapadma"/>
        <Literal>Vikachaabjae Kapitthadiphalae cha
Aavarthakae Kuchae Virahae Mukurae
Poorna-chandrae Sowndarya-bhavanae
Dhamillae Chandrashalayam Gramae Uddhata kopayoho
Tatakae Shakatae Chakravakae Kalakalaravae Shlaganae
So alapadmashcha Keertito Bharatagamae</Literal>
    </DataPropertyAssertion>
    <DataPropertyAssertion>
        <DataProperty IRI="#hasMeaning"/>
        <NamedIndividual IRI="#Anjali"/>
        <Literal>Used for the salutation to God, Teacher and the Learned. We hold the Anjali hasta above the head for the Gods, in front of the face for the teachers and in front of chest for the learned.</Literal>
    </DataPropertyAssertion>
    <DataPropertyAssertion>
        <DataProperty IRI="#hasSloka"/>
        <NamedIndividual IRI="#Anjali"/>
        <Literal>Devataguru Vipranaam
Namaskaraepyanukramaat
Karyas shiromukhorastho
Viniyoganjali karaha</Literal>
    </DataPropertyAssertion>
    <DataPropertyAssertion>
        <DataProperty IRI="#hasMeaning"/>
        <NamedIndividual IRI="#Arala"/>
        <Literal>To drink poison, nectar etc, Strong winds (storm, gale etc)</Literal>
    </DataPropertyAssertion>
    <DataPropertyAssertion>
        <DataProperty IRI="#hasSloka"/>
        <NamedIndividual IRI="#Arala"/>
        <Literal>Vishadhyam Amritam Panay Pranchanda Pavana</Literal>
    </DataPropertyAssertion>
    <DataPropertyAssertion>
        <DataProperty IRI="#hasMeaning"/>
        <NamedIndividual IRI="#Ardhachandra"/>
        <Literal>Moon, 8-day of the weaning moon, Seizing one by the throat, A spear, Offering to God, Plate, Origin or Birth, Waist, Thinking / Worrying, Contemplation, Meditation, Prayers, Touching the limbs, Greeting common people</Literal>
    </DataPropertyAssertion>
    <DataPropertyAssertion>
        <DataProperty IRI="#hasSloka"/>
        <NamedIndividual IRI="#Ardhachandra"/>
        <Literal>Chandray Krishna AshtamiBaaji Gala Hastartha Kepicha
BhalaYudha Devathanam Abishechana Karmani
Bukpathra Chudbava Katyaam Chintayam Athma-Vachakam
Dhyana Prathana Anganam-Sparsha
Prakruthanam Namaskaram Ardha Chandrani Jujyathay</Literal>
    </DataPropertyAssertion>
    <DataPropertyAssertion>
        <DataProperty IRI="#hasMeaning"/>
        <NamedIndividual IRI="#Ardhapataka"/>
        <Literal>Leaves, Writing pad, Bank of a river, To say Both, Saw, Knife, Flag, Gopuram of a Temple, Horns</Literal>
    </DataPropertyAssertion>
    <DataPropertyAssertion>
        <DataProperty IRI="#hasSloka"/>
        <NamedIndividual IRI="#Ardhapataka"/>
        <Literal>Pallavae phalakae theerae Ubhayorithivachakae
Krakachae Churikayam cha dhwajae gopura shringayoho
Yujyathae ardhapataakoyam Thathatkarmaprayogakae</Literal>
    </DataPropertyAssertion>
    <DataPropertyAssertion>
        <DataProperty IRI="#hasMeaning"/>
        <NamedIndividual IRI="#Avahittha"/>
        <Literal>To show Love, Catching the ball and Breasts.</Literal>
    </DataPropertyAssertion>
    <DataPropertyAssertion>
        <DataProperty IRI="#hasSloka"/>
        <NamedIndividual IRI="#Avahittha"/>
        <Literal>Srungara Natanechiva Leelaa
Kanduka dharane Kucharthe
Yujyate Soyamavahitthakaraabhidhaha</Literal>
    </DataPropertyAssertion>
    <DataPropertyAssertion>
        <DataProperty IRI="#hasMeaning"/>
        <NamedIndividual IRI="#Bherundha"/>
        <Literal>To show a bird couple.</Literal>
    </DataPropertyAssertion>
    <DataPropertyAssertion>
        <DataProperty IRI="#hasSloka"/>
        <NamedIndividual IRI="#Bherundha"/>
        <Literal>Bherundhapakshi Dampatyorbherundhaka Eteeritaha</Literal>
    </DataPropertyAssertion>
    <DataPropertyAssertion>
        <DataProperty IRI="#hasMeaning"/>
        <NamedIndividual IRI="#Bhramara"/>
        <Literal>Show honey bee, Parrot, Meditation, Show birds like kokila sarasa</Literal>
    </DataPropertyAssertion>
    <DataPropertyAssertion>
        <DataProperty IRI="#hasSloka"/>
        <NamedIndividual IRI="#Bhramara"/>
        <Literal>Bhramarecha shukae yogae
SarasaeKokiladishu bhramarakhyascha
Hastoyam Keerthitho Bharatagamae</Literal>
    </DataPropertyAssertion>
    <DataPropertyAssertion>
        <DataProperty IRI="#hasSloka"/>
        <NamedIndividual IRI="#Chakra"/>
        <Literal>Chakrahastassa vigneyachakrarthe viniyujyate</Literal>
    </DataPropertyAssertion>
    <DataPropertyAssertion>
        <DataProperty IRI="#hasSloka"/>
        <NamedIndividual IRI="#Chakra"/>
        <Literal>To show Chakra, the weapon of Lord Vishnu.</Literal>
    </DataPropertyAssertion>
    <DataPropertyAssertion>
        <DataProperty IRI="#hasMeaning"/>
        <NamedIndividual IRI="#Chandrakala"/>
        <Literal>Moon</Literal>
    </DataPropertyAssertion>
    <DataPropertyAssertion>
        <DataProperty IRI="#hasSloka"/>
        <NamedIndividual IRI="#Chandrakala"/>
        <Literal>Yesha Chandrakalaa chandrakallayame Vyujyate</Literal>
    </DataPropertyAssertion>
    <DataPropertyAssertion>
        <DataProperty IRI="#hasMeaning"/>
        <NamedIndividual IRI="#Chatura"/>
        <Literal>Fragrance from kastoori, Show small quantity, Gold and other metals, Wetness, Sadness, Taste, Eye, Differentiate color, Promise, Romance, Slow movement, Breaking, Seated, Molten butter, Oil</Literal>
    </DataPropertyAssertion>
    <DataPropertyAssertion>
        <DataProperty IRI="#hasSloka"/>
        <NamedIndividual IRI="#Chatura"/>
        <Literal>Kastooryam kinchidapyarthae
Swarnataamraadi lohakae
Aardrae khede rasaaswasae lochanae varnabhedakae
Pramanae sarasae mandhagamanae shakaleekrutae
Aasanae ghruta tailadao yujyatae chaturakaraha</Literal>
    </DataPropertyAssertion>
    <DataPropertyAssertion>
        <DataProperty IRI="#hasMeaning"/>
        <NamedIndividual IRI="#Dola"/>
        <Literal>Used in the beginning of a dance.</Literal>
    </DataPropertyAssertion>
    <DataPropertyAssertion>
        <DataProperty IRI="#hasSloka"/>
        <NamedIndividual IRI="#Dola"/>
        <Literal>Naatyarambhe Prayoktavyam Iti Natyavidovidhuhu</Literal>
    </DataPropertyAssertion>
    <DataPropertyAssertion>
        <DataProperty IRI="#hasMeaning"/>
        <NamedIndividual IRI="#Garuda"/>
        <Literal>To show a bird called Garuda.</Literal>
    </DataPropertyAssertion>
    <DataPropertyAssertion>
        <DataProperty IRI="#hasSloka"/>
        <NamedIndividual IRI="#Garuda"/>
        <Literal>Garudo Garudarthe cha Yujyate Baratagame</Literal>
    </DataPropertyAssertion>
    <DataPropertyAssertion>
        <DataProperty IRI="#hasMeaning"/>
        <NamedIndividual IRI="#Hamsapaksha"/>
        <Literal>To show number 6, Bridge, Impression of the nails, Way of doing thing</Literal>
    </DataPropertyAssertion>
    <DataPropertyAssertion>
        <DataProperty IRI="#hasSloka"/>
        <NamedIndividual IRI="#Hamsapaksha"/>
        <Literal>Shatsankhyayaam Setubandhe Nakharakankhanetatha Vidhane Hamsapakshoyam Keertito Bharatagame</Literal>
    </DataPropertyAssertion>
    <DataPropertyAssertion>
        <DataProperty IRI="#hasMeaning"/>
        <NamedIndividual IRI="#Hamsasya"/>
        <Literal>Tying the sacred thread of marriage, Advice, Decision, Excitement, Pearls &amp; other precious stones, Drawing, Fly, Drop of water, Wick of the lamp, Polishing, Searching, Jasmine &amp; other flowers, Drawing a line, Holding garland, To say ‘i am Brahma’, Saying ‘No’, Looking at the polished article</Literal>
    </DataPropertyAssertion>
    <DataPropertyAssertion>
        <DataProperty IRI="#hasSloka"/>
        <NamedIndividual IRI="#Hamsasya"/>
        <Literal>Mangalyasutra bandhechapyupadesha Vinishchayae Romanchae mouktikadoucha
Chitrasamlekhanae thatha Damshathua jalabindoucha Deepavartiprasaranae
Nikashae shodhanae mallikadou cha Rekhavalekhanae malayaamvahanae
Sohambhavanayancha Roopakae Naasteetivachanechapi Nikashanamchabhavane
Krutakrutyepi Hamsasyaha Eerito Bharatagame</Literal>
    </DataPropertyAssertion>
    <DataPropertyAssertion>
        <DataProperty IRI="#hasMeaning"/>
        <NamedIndividual IRI="#Kangula"/>
        <Literal>To show Lemon, Breasts of a teenager, Flower called Kalhara, A bird called Chakora, Beetle nut, Jingles, Tablets, A bird called Chataka, Kangoola Hasta is used</Literal>
    </DataPropertyAssertion>
    <DataPropertyAssertion>
        <DataProperty IRI="#hasSloka"/>
        <NamedIndividual IRI="#Kangula"/>
        <Literal>Lakuchasya Phale Balakuche Kalharake tatha
Chakore Kramuke Baalakinkinyam Ghutikadike
Chaatake Yujyatechayam Kangoolakaranaamakaha</Literal>
    </DataPropertyAssertion>
    <DataPropertyAssertion>
        <DataProperty IRI="#hasMeaning"/>
        <NamedIndividual IRI="#Kapitham"/>
        <Literal>Goddess Lakshmi, Goddess Saraswati, Going Around, Holding the cymbals (Tala), Milking the cows, Putting eye liners, Holding Flowers, Holding the Saree(pallu), Draping a cloth on the face, To Hold Lamp and Incense</Literal>
    </DataPropertyAssertion>
    <DataPropertyAssertion>
        <DataProperty IRI="#hasSloka"/>
        <NamedIndividual IRI="#Kapitham"/>
        <Literal>Lakshmyamchiva Saraswatyam Veshtane Taladharane
Godohanechanjanecha Leelattasumadharane
Chelanchaladigrahane Patasyivavakuntane
Dhoopadeepaarchanechapi Kapithasamprayujyate</Literal>
    </DataPropertyAssertion>
    <DataPropertyAssertion>
        <DataProperty IRI="#hasMeaning"/>
        <NamedIndividual IRI="#Kapotha"/>
        <Literal>To show respectful salutation to the teachers, as a mark of acceptance and to show politeness (vinayam).</Literal>
    </DataPropertyAssertion>
    <DataPropertyAssertion>
        <DataProperty IRI="#hasSloka"/>
        <NamedIndividual IRI="#Kapotha"/>
        <Literal>Pranaamae Gurusambhashae
Vinayangi kritaeshwayam</Literal>
    </DataPropertyAssertion>
    <DataPropertyAssertion>
        <DataProperty IRI="#hasMeaning"/>
        <NamedIndividual IRI="#Karkata"/>
        <Literal>To show the arrival of a crowd, showing the belly, blowing the shanku (counch), twisting &amp; stretching the limbs and bending branch of a tree.</Literal>
    </DataPropertyAssertion>
    <DataPropertyAssertion>
        <DataProperty IRI="#hasSloka"/>
        <NamedIndividual IRI="#Karkata"/>
        <Literal>Samoohaa gamanae Tundadarshanae
Shankhapoorane Angaanaam Motane
Shaakhonnamaanecha Niyujyate</Literal>
    </DataPropertyAssertion>
    <DataPropertyAssertion>
        <DataProperty IRI="#hasSloka"/>
        <NamedIndividual IRI="#Kartaree_swastika"/>
        <Literal>Shakhaasucha Adri Shikhare
Vruksheshucha Niyujyate</Literal>
    </DataPropertyAssertion>
    <DataPropertyAssertion>
        <DataProperty IRI="#hasSloka"/>
        <NamedIndividual IRI="#Kartaree_swastika"/>
        <Literal>To show the branches of a tree, tip of Mountains and Trees.</Literal>
    </DataPropertyAssertion>
    <DataPropertyAssertion>
        <DataProperty IRI="#hasMeaning"/>
        <NamedIndividual IRI="#Kartarimukha"/>
        <Literal>Separation of man and women, Opposition or overturning, Stealing or rolling, Corner of the eye, Death, Disagreement, Lightning, Married couple fights and separate / In separation from the loved one, To fall down, A creeper</Literal>
    </DataPropertyAssertion>
    <DataPropertyAssertion>
        <DataProperty IRI="#hasSloka"/>
        <NamedIndividual IRI="#Kartarimukha"/>
        <Literal>Shtripum-sayoosthu-vishlasya
Viparyaa-sapaday-pivaaLuntana
Nayana-amtham Marana Bheda-bhavana
Vidhyu-dartha Api-yekashiyaa-viraha Patana Latayan
